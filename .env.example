# LLM Providers — comma-separated for key rotation
GROQ_API_KEYS=your_groq_api_key
GEMINI_API_KEYS=your_gemini_api_key
CEREBRAS_API_KEY=your_cerebras_api_key  # free at cloud.cerebras.ai
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key  # free at build.nvidia.com

# Search & Scraping (get free keys at tavily.com)
TAVILY_API_KEY_DEEP=your_tavily_key_1
TAVILY_API_KEY_GENERAL=your_tavily_key_2

# Storage (get free at upstash.com)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Scheduling (get free at upstash.com/qstash)
QSTASH_TOKEN=your_qstash_token
QSTASH_SIGNING_KEY=your_qstash_signing_key

# Email (get free at resend.com — 3K emails/month)
RESEND_API_KEY=your_resend_key

# Observability (get free at cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Notifications
DISCORD_WEBHOOK_URL=

# Security — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
HMAC_SECRET=generate_a_random_secret_here

# App
ENVIRONMENT=development
