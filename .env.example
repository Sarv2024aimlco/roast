# ── App ────────────────────────────────────────────────────
# Set to "production" on server, "development" locally
ENVIRONMENT=development

# Comma-separated allowed origins for CORS (required in production)
# e.g. https://roast.dev,https://www.roast.dev
# Leave empty in development — localhost variants are allowed automatically
ALLOWED_ORIGINS=

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Required in production, optional in development
HMAC_SECRET=generate_a_random_secret_here

# ── LLM Providers ──────────────────────────────────────────
# Comma-separated for key rotation — e.g. "key1,key2"
GROQ_API_KEYS=your_groq_api_key
GEMINI_API_KEYS=your_gemini_api_key
CEREBRAS_API_KEY=your_cerebras_api_key
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key

# ── Search & Scraping ──────────────────────────────────────
# Get free keys at tavily.com (1000 credits/month each)
TAVILY_API_KEY_DEEP=your_tavily_key_1
TAVILY_API_KEY_GENERAL=your_tavily_key_2

# ── Storage ────────────────────────────────────────────────
# Get free at upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Scheduling ─────────────────────────────────────────────
# Get free at upstash.com/qstash — needed for monthly cron refresh
QSTASH_TOKEN=your_qstash_token
QSTASH_SIGNING_KEY=your_qstash_signing_key

# ── Email ──────────────────────────────────────────────────
# Get free at resend.com (3K emails/month)
# Optional — token system works without it in dev (token returned in response)
RESEND_API_KEY=your_resend_key

# ── Observability ──────────────────────────────────────────
# Get free at cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Notifications ──────────────────────────────────────────
# Optional — Discord webhook for cron job alerts
DISCORD_WEBHOOK_URL=
